# ============================================================
# QUANTUM-FORGE Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit the .env file to version control!
# ============================================================

# --- Binance API ---
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# Set to 'true' for Binance testnet
BINANCE_TESTNET=false

# --- Alpha Vantage (optional) ---
ALPHA_VANTAGE_API_KEY=

# --- Database ---
POSTGRES_PASSWORD=quantum_secure_password_2024
DATABASE_URL=postgresql://quantum_user:quantum_secure_password_2024@localhost:5432/quantum_forge

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO
TRADING_MODE=paper
# Symbols (comma-separated)
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT

# --- Capital & Risk ---
INITIAL_CAPITAL=100000
MAX_POSITION_SIZE=1000000
RISK_TOLERANCE=0.02
MAX_DAILY_LOSS=50000

# --- Alerting (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=

# --- LLM (optional) ---
LLM_ENABLED=false
LLM_MODEL_PATH=models/llm/

# --- Monitoring ---
GRAFANA_PASSWORD=quantum_admin_2024
JUPYTER_TOKEN=quantum_research_2024
PROMETHEUS_PORT=9090

# --- Firm Config ---
FIRM_CONFIG=demo

# --- Performance ---
MAX_WORKERS=8
NUMBA_CACHE_DIR=/tmp/numba_cache